{
  "name": "info-butler",
  "version": "0.1.0",
  "description": "智能信息管家 - 自动整理信息、提取行动项、生成周报复盘",
  "scripts": {
    "dev": "concurrently -n \"backend,frontend\" -c \"blue,green\" \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "uv run uvicorn backend.main:app --host 0.0.0.0 --port 8001 --reload",
    "dev:frontend": "cd frontend && npm run dev",
    "start": "npm run dev",
    "stop": "taskkill /FI \"WINDOWTITLE eq Info-Butler*\" /F"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
