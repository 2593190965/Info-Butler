APP_NAME=Info-Butler
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
API_KEY=your-api-key-here

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=info_butler
MYSQL_PASSWORD=butler_pass
MYSQL_DATABASE=info_butler

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

DIFY_API_URL=https://api.dify.ai/v1
DIFY_API_KEY=app-xxxxxxxxxxxxxxx
DIFY_WORKFLOW_ID=your-workflow-id

# Feishu Bot Configuration
# 注意：以下是必需配置，请根据 FEISHU_SETUP_GUIDE.md 获取这些值
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx
FEISHU_APP_ID=cli_xxxxxxxxxxxx  # 必需：从飞书开放平台获取
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx  # 必需：从飞书开放平台获取
FEISHU_ENCRYPT_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx  # 可选：用于验证回调请求
FEISHU_VERIFICATION_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx  # 可选：用于验证回调请求
FEISHU_REMINDER_ADVANCE_DAYS=1  # 提前多少天发送到期提醒

